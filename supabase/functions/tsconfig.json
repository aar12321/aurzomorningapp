{
  "compilerOptions": {
    "lib": ["esnext", "dom", "dom.iterable"],
    "strict": false,
    "allowJs": true,
    "skipLibCheck": true,
    "noEmit": true,
    "module": "esnext",
    "target": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": []
  },
  "include": ["./**/*.ts", "deno.d.ts", "types.d.ts"],
  "exclude": ["node_modules"]
}

